---
import {ClientRouter} from 'astro:transitions';
import '../styles/globals.css';

import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SafeTopoBackground from "../components/SafeTopoBackground.tsx";
import SafeLoadingOverlay from "../components/SafeLoadingOverlay.tsx";
import CommandPalette from "../components/CommandPalette.astro";
import CommandPaletteHint from "../components/CommandPaletteHint.astro";

import {SITE} from '../config';

interface Props {
    title?: string;
    scrollSmooth?: boolean;
    description?: string;
    tags?: string[];
    author?: string;
    imageOg?: string;
    canonicalURL?: string;
}

const {
    title = SITE.title,
    description = SITE.description,
    tags = SITE.tags,
    author = SITE.author,
    scrollSmooth = false,
    canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
    imageOg = SITE.ogImage,
} = Astro.props;
---

<!doctype html>
<html lang={SITE.lang ?? "en"} class={`dark bg-[var(--color-background-dark)]${scrollSmooth ? " scroll-smooth" : ""}`}>
<head>
    <meta name="msapplication-TileColor" content="#000000"/>
    <meta name="viewport" content="width=device-width"/>
    <meta charset="UTF-8"/>
    <meta name="generator" content={Astro.generator}/>

    <meta name="title" content={title}/>
    <meta name="description" content={description}/>
    <meta name="keywords" content={tags.join(', ')}/>
    <meta name="author" content={author}/>
    <link rel="sitemap" href="/sitemap-index.xml"/>
    <link rel="icon" href={SITE.favicon}/>
    <link rel="canonical" href={canonicalURL}/>


    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title}/>
    <meta property="og:description" content={description}/>
    <meta property="og:url" content={canonicalURL}/>
    <meta property="og:image" content={imageOg}/>
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image"/>
    <meta property="twitter:url" content={canonicalURL}/>
    <meta property="twitter:title" content={title}/>
    <meta property="twitter:description" content={description}/>
    <meta property="twitter:image" content={imageOg}/>

    <title>{title}</title>
    <ClientRouter/>
</head>
<body class="min-h-screen bg-transparent font-body text-slate-800 dark:text-slate-200 selection:bg-primary selection:text-white">

<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2">Skip to main content</a>

<script is:inline>
  document.documentElement.classList.add('dark');
</script>

<div id="loading-overlay" class="fixed inset-0 z-50 bg-[var(--color-background-dark)]" aria-hidden="true"></div>
<SafeLoadingOverlay client:only="react" />
<SafeTopoBackground client:only="react" />
<CommandPalette />
<CommandPaletteHint />
<SiteHeader />

<main id="main-content" class="relative z-10 max-w-7xl mx-auto px-6 py-12">
    <slot/>
</main>

<SiteFooter />
</body>
</html>

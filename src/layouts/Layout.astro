---
import {ClientRouter} from 'astro:transitions';
import '@/styles/globals.css';

import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import TopoBackground from "../components/TopoBackground.tsx";
import CommandPalette from "../components/CommandPalette.astro";
import CommandPaletteHint from "../components/CommandPaletteHint.astro";

import {SITE} from '@/config';

interface Props {
    title?: string;
    scrollSmooth?: boolean;
    description?: string;
    tags?: string[];
    author?: string;
    imageOg?: string;
    canonicalURL?: string;
}

const {
    title = SITE.title,
    description = SITE.description,
    tags = SITE.tags,
    author = SITE.author,
    scrollSmooth = false,
    canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
    imageOg = SITE.ogImage,
} = Astro.props;
---

<!doctype html>
<html lang={SITE.lang ?? "en"} class={`dark bg-[var(--color-background-dark)]${scrollSmooth ? " scroll-smooth" : ""}`}>
<head>
    <meta name="msapplication-TileColor" content="#000000"/>
    <meta name="viewport" content="width=device-width"/>
    <meta charset="UTF-8"/>
    <meta name="generator" content={Astro.generator}/>

    <meta name="title" content={title}/>
    <meta name="description" content={description}/>
    <meta name="keywords" content={tags.join(', ')}/>
    <meta name="author" content={author}/>
    <link rel="sitemap" href="/sitemap-index.xml"/>
    <link rel="icon" href={SITE.favicon}/>
    <link rel="canonical" href={canonicalURL}/>


    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title}/>
    <meta property="og:description" content={description}/>
    <meta property="og:url" content={canonicalURL}/>
    <meta property="og:image" content={imageOg}/>
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image"/>
    <meta property="twitter:url" content={canonicalURL}/>
    <meta property="twitter:title" content={title}/>
    <meta property="twitter:description" content={description}/>
    <meta property="twitter:image" content={imageOg}/>

    <title>{title}</title>
    <ClientRouter/>
</head>
<body class="min-h-screen bg-transparent font-body text-slate-800 dark:text-slate-200 selection:bg-primary selection:text-white">

<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2">Skip to main content</a>

<script is:inline>
  document.documentElement.classList.add('dark');
</script>

<div id="loading-overlay" class="fixed inset-0 z-50 bg-[var(--color-background-dark)]" style="transition:opacity .5s" aria-hidden="true"></div>
<script is:inline>
  (function () {
    function getOverlay() {
      return document.getElementById('loading-overlay');
    }

    // Captures the target at call-time so each invocation operates on the
    // correct overlay instance even after a DOM swap replaces the element.
    function hideOverlay(delay) {
      var target = getOverlay();
      if (!target) return;
      setTimeout(function () {
        target.style.opacity = '0';
        setTimeout(function () {
          target.style.display = 'none';
        }, 500);
      }, delay);
    }

    var o = getOverlay();
    if (!o) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      o.remove();
      return;
    }

    // Hide the overlay on every (re-)execution — covers both initial page
    // load and post-swap re-runs triggered by Astro's ClientRouter.
    hideOverlay(600);

    // Register navigation listeners only once to prevent accumulation across
    // repeated script re-runs on each client-side navigation.
    // NOTE: document.documentElement.dataset is reset by Astro's <html> attribute
    // sync on every swap, so the guard must live on window instead.
    if (window.__astroOverlayListeners) return;
    window.__astroOverlayListeners = true;

    document.addEventListener('astro:before-swap', function () {
      var el = getOverlay();
      if (!el) return;
      el.style.display = '';
      el.style.opacity = '1';
    });

    document.addEventListener('astro:page-load', function () {
      hideOverlay(300);
    });
  })();
</script>
<TopoBackground client:only="react" />
<CommandPalette />
<CommandPaletteHint />
<SiteHeader />

<main id="main-content" class="relative z-10 max-w-7xl mx-auto px-6 py-12">
    <slot/>
</main>

<SiteFooter />
</body>
</html>

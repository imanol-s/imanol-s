---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import { ME, SITE } from '../config';
import workExperience from '../data/Jobs';
import education from '../data/education';
import { getTechIconPath } from '../data/techIcons';

const allProjects = (await getCollection('projects'))
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());

function fmtDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short',
    year: 'numeric',
    timeZone: 'UTC',
  }).toUpperCase();
}

const timelineJobs = workExperience.slice(0, 3);
const edu = education[0];
---

<Layout title={`${SITE.author} | Portfolio`} description={ME.aboutMe} scrollSmooth={true}>
  <HeroSection />

  <!-- ═══ PROJECTS ═══ -->
  <section class="mb-32 scroll-mt-20" id="projects" aria-label="Projects">
    <div class="flex items-end justify-between mb-8 border-b border-slate-200 dark:border-slate-800 pb-4">
      <div>
        <h2 class="text-3xl font-display font-bold">PROJECTS</h2>
      </div>
    </div>
    <div id="projects-track" class="horizontal-scroll-snap">
      {allProjects.map((project) => (
        <a href={`/projects/${project.id}`} class="group flex flex-col cad-border bg-slate-50 dark:bg-slate-900 shadow-sm cursor-pointer hover:border-primary hover:bg-white dark:hover:bg-slate-800 transition-colors">
          <div class="relative h-[160px] overflow-hidden border-b border-slate-200 dark:border-slate-800">
            <Image
              src={project.data.cover}
              alt={project.data.title}
              class="absolute inset-0 w-full h-full object-cover grayscale opacity-60 group-hover:scale-105 transition-transform duration-1000"
              width={350}
              height={160}
              sizes="(min-width: 768px) 350px, 300px"
            />
            <div class="absolute inset-0 bg-primary/10 mix-blend-multiply"></div>
          </div>
          <div class="p-5 flex flex-col flex-grow">
            <h3 class="text-lg font-display font-bold mb-3">
              {project.data.title}
            </h3>
            <p class="text-xs text-slate-700 dark:text-slate-200 leading-relaxed flex-grow">
              {project.data.summary}
            </p>
          </div>
        </a>
      ))}
    </div>

    <div class="flex justify-end gap-2 mt-4">
      <button id="carousel-prev" class="cad-border px-3 py-1.5 font-display text-xs uppercase tracking-widest text-slate-500 hover:text-white transition-colors disabled:opacity-30 disabled:cursor-not-allowed" aria-label="Previous projects">
        ← PREV
      </button>
      <button id="carousel-next" class="cad-border px-3 py-1.5 font-display text-xs uppercase tracking-widest text-slate-500 hover:text-white transition-colors disabled:opacity-30 disabled:cursor-not-allowed" aria-label="Next projects">
        NEXT →
      </button>
    </div>

  </section>

  <!-- ═══ EXPERIENCE + TECH SPECS ═══ -->
  <section class="grid grid-cols-1 lg:grid-cols-12 gap-16 mb-32 scroll-mt-20" id="experience" aria-label="Professional Experience">
    <div class="lg:col-span-8">
      <div class="border-b border-slate-200 dark:border-slate-800 pb-4 mb-8">
        <h2 class="text-2xl font-display font-bold uppercase">Professional Experience</h2>
      </div>
      <div class="space-y-12">
        {timelineJobs.map((job, i) => (
          <div class="relative pl-8 border-l border-slate-200 dark:border-slate-800">
            {i === 0 ? (
              <div class="absolute -left-1.5 top-0 w-3 h-3 bg-primary ring-4 ring-[var(--color-background-light)] dark:ring-[var(--color-background-dark)]"></div>
            ) : (
              <div class="absolute -left-1.5 top-0 w-3 h-3 border border-primary bg-[var(--color-background-light)] dark:bg-[var(--color-background-dark)] ring-4 ring-[var(--color-background-light)] dark:ring-[var(--color-background-dark)]"></div>
            )}
            <div class="cad-border bg-slate-50 dark:bg-slate-900 p-5 hover:border-primary hover:bg-white dark:hover:bg-slate-800 transition-colors">
              <div class="text-xs font-display text-primary mb-1 font-bold">
                {job.startDate ? fmtDate(job.startDate) : ''} — {job.currentJob ? 'PRESENT' : job.endDate ? fmtDate(job.endDate) : ''}
              </div>
              <h3 class="text-xl font-display font-bold text-slate-900 dark:text-white">
                {job.title}
              </h3>
              <p class="text-slate-600 dark:text-slate-400 text-sm mb-4">
                {job.company} / {job.location}
              </p>
              <p class="text-slate-800 dark:text-slate-200 leading-relaxed mb-4">
                {job.description}
              </p>
              {i === 0 && (
                <ul class="text-sm space-y-2 text-slate-700 dark:text-slate-200 list-disc list-inside marker:text-primary">
                  {job.goals.slice(0, 3).map((goal) => (
                    <li>{goal}</li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))}

      </div>
    </div>

    <div id="tech-stack-sidebar" class="lg:col-span-4">
      <div class="border-b border-slate-200 dark:border-slate-800 pb-4 mb-8">
        <h2 class="text-2xl font-display font-bold uppercase">Tech Stack</h2>
      </div>
      <div class="space-y-8">
        <!-- Education -->
        {edu && (
          <div>
            <h3 class="text-xs uppercase tracking-widest text-slate-500 mb-3 font-bold">
              Education
            </h3>
            <div class="cad-border bg-slate-50 dark:bg-slate-900 p-5 font-display text-sm hover:border-primary hover:bg-white dark:hover:bg-slate-800 transition-colors">
              <div class="text-xs text-primary mb-1 font-bold">
                {edu.endDate ? fmtDate(edu.endDate) : ''}
              </div>
              <div class="font-bold text-slate-900 dark:text-white">
                {edu.title}
              </div>
              <p class="text-slate-600 dark:text-slate-400 text-xs mt-0.5">
                {edu.school}
              </p>
            </div>
          </div>
        )}

        <!-- Core Languages -->
        <div>
          <h3 class="text-xs uppercase tracking-widest text-slate-500 mb-3 font-bold">
            Core Languages
          </h3>
          <div class="grid grid-cols-2 gap-3">
            {ME.coreLanguages.map((tech) => {
              const iconPath = getTechIconPath(tech);
              return (
                <div class="p-3 cad-border bg-slate-50 dark:bg-slate-900 flex items-center gap-2 hover:border-primary hover:bg-white dark:hover:bg-slate-800 transition-colors group">
                  {iconPath && (
                    <img
                      src={iconPath}
                      alt={`${tech} icon`}
                      width="16"
                      height="16"
                      loading="lazy"
                      decoding="async"
                      class="group-hover:scale-110 transition-transform"
                    />
                  )}
                  <span class="text-sm font-display">{tech}</span>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Competencies -->
        <div>
          <h3 class="text-xs uppercase tracking-widest text-slate-500 mb-4 font-bold">
            Competencies
          </h3>
          <ul class="flex flex-col gap-2 font-display">
            {ME.competencies.map((item) => (
              <li class="group flex items-center justify-between px-3 py-2 bg-slate-50 dark:bg-slate-900 cad-border hover:border-primary hover:bg-white dark:hover:bg-slate-800 transition-colors cursor-default">
                <span class="text-sm text-slate-800 dark:text-slate-200 tracking-tight font-medium">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Communication -->
        <div class="pt-2">
          <h3 class="text-xs uppercase tracking-widest text-slate-500 mb-3 font-bold">
            Communication
          </h3>
          <div class="cad-border bg-slate-50 dark:bg-slate-900 p-5 font-display text-sm hover:border-primary hover:bg-white dark:hover:bg-slate-800 transition-colors">
            {ME.languages.map((lang, i) => (
              <div class:list={["flex justify-between items-center", { "mb-2": i < ME.languages.length - 1 }]}>
                <span class="text-slate-700 dark:text-slate-200">{lang.name.toUpperCase()}</span>
                <span class="text-primary font-bold text-xs">{lang.level.toUpperCase()}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ABOUT ═══ -->
  <section id="about" class="mb-32 scroll-mt-20" aria-label="About">
    <div class="flex items-end justify-between mb-8 border-b border-slate-200 dark:border-slate-800 pb-4">
      <h2 class="text-3xl font-display font-bold">ABOUT</h2>
    </div>
    {ME.bio && (
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <div class="lg:col-span-8">
          <p class="text-xl text-slate-700 dark:text-slate-200 leading-relaxed font-light mb-8">
            {ME.bio}
          </p>
        </div>
      </div>
    )}
  </section>
</Layout>

<script>
  function initCarousel() {
    const track = document.getElementById("projects-track");
    const prev = document.getElementById("carousel-prev") as HTMLButtonElement | null;
    const next = document.getElementById("carousel-next") as HTMLButtonElement | null;
    if (!track || !prev || !next) return;

    const scrollAmount = () => track.clientWidth * 0.85;

    // Arrow state
    function updateArrows() {
      if (!track || !prev || !next) return;
      prev.disabled = track.scrollLeft <= 1;
      next.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 1;
    }

    prev.addEventListener("click", () => track.scrollBy({ left: -scrollAmount() }));
    next.addEventListener("click", () => track.scrollBy({ left: scrollAmount() }));
    track.addEventListener("scroll", updateArrows, { passive: true });
    new ResizeObserver(updateArrows).observe(track);
    updateArrows();

    // Mouse drag — only activate after pointer moves beyond threshold
    let isPointerDown = false;
    let isDragging = false;
    let startX = 0;
    let startScroll = 0;
    let pointerId = -1;

    track.addEventListener("pointerdown", (e: PointerEvent) => {
      if (e.button !== 0) return;
      isPointerDown = true;
      isDragging = false;
      startX = e.clientX;
      startScroll = track.scrollLeft;
      pointerId = e.pointerId;
    });

    track.addEventListener("pointermove", (e: PointerEvent) => {
      if (!isPointerDown) return;
      const dx = Math.abs(e.clientX - startX);
      if (!isDragging && dx > 5) {
        isDragging = true;
        track.setPointerCapture(pointerId);
        track.style.cursor = "grabbing";
        track.style.userSelect = "none";
      }
      if (isDragging) {
        track.scrollLeft = startScroll - (e.clientX - startX);
      }
    });

    track.addEventListener("pointerup", () => {
      if (isDragging) {
        track.releasePointerCapture(pointerId);
        track.style.cursor = "";
        track.style.userSelect = "";
        // Prevent click on links after drag
        track.addEventListener("click", (ev) => ev.preventDefault(), { once: true, capture: true });
      }
      isPointerDown = false;
      isDragging = false;
    });
  }

  initCarousel();

  if (!(window as unknown as Record<string, boolean>).__carouselListenerRegistered) {
    (window as unknown as Record<string, boolean>).__carouselListenerRegistered = true;
    document.addEventListener("astro:after-swap", initCarousel);
  }
</script>

---
import { Image } from "astro:assets";

interface Props {
  id: string;
  title: string;
  description: string;
  publishDate: Date;
  tags: string[];
  cover: {
    src: ImageMetadata;
    alt?: string;
  };
}

const { id, title, description, publishDate, tags, cover } =
  Astro.props as Props;
---

<a
  href={`/blog/${id}`}
  aria-label={`Read post about ${title}`}
  class="group flex flex-col md:flex-row md:items-center gap-5 p-5 cad-border bg-slate-50 dark:bg-slate-900 hover:bg-white dark:hover:bg-slate-800 transition-colors"
>
  <div class="flex-none w-full md:w-40 h-40 overflow-hidden border border-slate-200 dark:border-slate-800">
    <Image
      transition:name={`${id}-image`}
      src={cover.src}
      alt={cover.alt ?? title}
      class="w-full h-full object-cover"
      widths={[160, 320]}
      sizes="(max-width: 768px) 100vw, 160px"
    />
  </div>
  <div class="flex flex-col gap-2">
    <div class="flex items-center gap-1.5">
      <div class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-slate-500" aria-hidden="true"><path d="M12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22ZM12 20C16.4183 20 20 16.4183 20 12C20 7.58172 16.4183 4 12 4C7.58172 4 4 7.58172 4 12C4 16.4183 7.58172 20 12 20ZM13 12H17V14H11V7H13V12Z"></path></svg>
        <time
          class="text-sm text-slate-500"
          datetime={publishDate.toISOString()}
        >
          {publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}
        </time>
      </div>
      <span class="text-slate-500"> &middot; </span>
      <div class="flex gap-2">
        {tags.map((tag) => <span class="text-sm text-slate-500">#{tag}</span>)}
      </div>
    </div>
    <h3 class="text-xl font-display font-bold text-slate-900 dark:text-white">{title}</h3>
    <div class="flex flex-col gap-4">
      <p class="text-sm text-slate-700 dark:text-slate-200 leading-relaxed">{description}</p>
    </div>
  </div>
</a>

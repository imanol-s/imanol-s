---
import { getCollection } from 'astro:content';
import { Picture } from 'astro:assets';
import { getSortedProjects } from '@/data/projectCollection';

const allProjects = getSortedProjects(await getCollection('projects'));
---

<section class="mb-32 scroll-mt-20 render-deferred" id="projects" aria-label="Projects">
  <div class="flex items-end justify-between mb-8 border-b border-slate-200 dark:border-slate-800 pb-4">
    <div>
      <h2 class="text-3xl font-display font-bold">PROJECTS</h2>
    </div>
  </div>
  <div id="projects-track" class="horizontal-scroll-snap">
    {allProjects.map((project) => (
      <a href={`/projects/${project.id}`} class="group flex flex-col cad-border bg-slate-50 dark:bg-slate-900 shadow-sm cursor-pointer hover:border-primary hover:bg-white dark:hover:bg-slate-800 transition-colors">
        <div class="relative h-[160px] overflow-hidden border-b border-slate-200 dark:border-slate-800">
          <Picture
            src={project.data.cover}
            alt={project.data.title}
            class="absolute inset-0 w-full h-full object-cover grayscale opacity-60 group-hover:scale-105 transition-transform duration-1000"
            formats={['avif']}
            fallbackFormat="webp"
            widths={[300, 350]}
            sizes="(min-width: 768px) 350px, 300px"
            loading="eager"
            decoding="sync"
          />
          <div class="absolute inset-0 bg-primary/10 mix-blend-multiply"></div>
        </div>
        <div class="p-5 flex flex-col flex-grow">
          <h3 class="text-lg font-display font-bold mb-3">
            {project.data.title}
          </h3>
          <p class="text-xs text-slate-700 dark:text-slate-200 leading-relaxed flex-grow">
            {project.data.summary}
          </p>
        </div>
      </a>
    ))}
  </div>

  <div class="flex justify-end gap-2 mt-4">
    <button id="carousel-prev" class="cad-border px-3 py-1.5 font-display text-xs uppercase tracking-widest text-slate-500 hover:text-white transition-colors disabled:opacity-30 disabled:cursor-not-allowed" aria-label="Previous projects">
      ← PREV
    </button>
    <button id="carousel-next" class="cad-border px-3 py-1.5 font-display text-xs uppercase tracking-widest text-slate-500 hover:text-white transition-colors disabled:opacity-30 disabled:cursor-not-allowed" aria-label="Next projects">
      NEXT →
    </button>
  </div>
</section>

<script>
  import { initCarousel } from '../utils/carousel';
  import { CAROUSEL } from '../utils/domContracts';

  let cleanup: (() => void) | undefined;
  document.addEventListener('astro:page-load', () => {
    cleanup?.();
    const track = document.getElementById(CAROUSEL.trackId) as HTMLElement | null;
    const prev = document.getElementById(CAROUSEL.prevId) as HTMLButtonElement | null;
    const next = document.getElementById(CAROUSEL.nextId) as HTMLButtonElement | null;
    if (track && prev && next) cleanup = initCarousel(track, prev, next);
  });
</script>

---
// Back button component
---
<a href="/blog"
        class="inline-flex h-10 w-10 items-center justify-center cad-border bg-slate-50 dark:bg-slate-900 text-slate-700 dark:text-slate-200 hover:text-primary transition-colors focus-ring"
        aria-label="Go back">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
        <path d="M7.82843 10.9999H20V12.9999H7.82843L13.1924 18.3638L11.7782 19.778L4 11.9999L11.7782 4.22168L13.1924 5.63589L7.82843 10.9999Z"></path>
    </svg>
</a>

<script>
  const btn = document.querySelector('a[aria-label="Go back"]');
  btn?.addEventListener('click', (e) => {
    if (history.length > 1) {
      e.preventDefault();
      history.back();
    }
  });
</script>

---
import { Picture } from 'astro:assets';
import TypewriterText from './TypewriterText.tsx';
import { ME, SOCIALS } from '../config';
import profileImage from '../assets/Profile-1.png';

const github = SOCIALS.find(s => s.name === 'GitHub');
const linkedin = SOCIALS.find(s => s.name === 'LinkedIn');
---

<section class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center mb-32" aria-label="Hero">
  <div class="lg:col-span-7">
    <TypewriterText client:load text={ME.name} />
    <div class="text-lg md:text-xl font-display text-primary mb-8 tracking-tight">
      {ME.profession.join(' \u2022 ')}
    </div>
    <p class="text-xl text-slate-700 dark:text-slate-200 max-w-2xl mb-10 leading-relaxed font-light">
      {ME.aboutMe}
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 w-full">
      {ME.focusAreas.map((area) => (
        <div class="p-5 cad-border bg-slate-50 dark:bg-slate-900 flex flex-col justify-center items-start group hover:border-primary hover:bg-white dark:hover:bg-slate-800 transition-colors">
          <p class="font-display font-bold text-slate-900 dark:text-white mb-1">
            {area}
          </p>
        </div>
      ))}
    </div>
  </div>
  <div class="lg:col-span-5 flex justify-center">
    <div class="relative group">
      <div class="absolute -inset-4 border border-dashed border-primary/40 group-hover:scale-105 transition-transform duration-700"></div>
      <Picture
        src={profileImage}
        alt={`${ME.name} portrait`}
        class="w-64 h-64 grayscale contrast-125 object-cover cad-border brightness-90"
        formats={['avif']}
        fallbackFormat="webp"
        widths={[256, 512]}
        sizes="256px"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute bottom-4 -right-8 flex flex-col gap-2">
        {github?.show && (
          <a
            class="w-10 h-10 bg-[var(--color-background-dark)] text-white flex items-center justify-center hover:bg-primary transition-colors focus-ring"
            href={github.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </a>
        )}
        {linkedin?.show && (
          <a
            class="w-10 h-10 bg-[var(--color-background-dark)] text-white flex items-center justify-center hover:bg-primary transition-colors focus-ring"
            href={linkedin.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        )}
        <a
          class="w-10 h-10 bg-[var(--color-background-dark)] text-white flex items-center justify-center hover:bg-primary transition-colors focus-ring"
          href={`mailto:${ME.contactInfo.email}`}
          aria-label="Email"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
